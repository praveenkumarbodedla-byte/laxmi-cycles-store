  "about": {
    "storyLabel": "எங்கள் கதை",
    "storyTitle": "வெறும் சைக்கிள் கடை மட்டுமல்ல",
    "storyDesc": "லக்ஷ்மி சைக்கிள்ஸ் ஸ்டோர் ஒரு எளிய நம்பிக்கையின் அடிப்படையில் கட்டப்பட்டது: ஒவ்வொரு நபரும் பிரீமியம் சைக்கிள் ஓட்டும் अनुभवத்திற்குத் தகுதியானவர்கள். 2009 முதல், ஹைதராபாத்தில் தரமான சைக்கிள்கள், நிபுணர் அறிவுரைகள் மற்றும் சிறந்த சேவைக்கான மிகவும் நம்பகமான இடமாக நாங்கள் இருக்கிறோம்.",
    "valuesTitle": "எங்கள் மதிப்புகள்",
    "journeyTitle": "எங்கள் பயணம்",
    "values": {
      "v1": {
        "title": "தரம் முதலில்",
        "desc": "நிரூபிக்கப்பட்ட தரம் கொண்ட நம்பகமான உற்பத்தியாளர்களிடமிருந்து மட்டுமே சிறந்த சைக்கிள்களை விற்கிறோம்."
      },
      "v2": {
